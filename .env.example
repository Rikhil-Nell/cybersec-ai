# Chatbot demo (/demo) — OpenAI Responses API with web_search built-in tool
OPENAI_API_KEY=sk-...

# Model for POST /api/chat (Responses API, not Chat Completions)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Built-in web_search tool for current incidents (set false to disable)
OPENAI_CHAT_ENABLE_WEB_SEARCH=true

# Optional: deanonymizer audit fallback if no OpenAI key
# ANTHROPIC_API_KEY=sk-ant-...

# --- Rate limits (per IP, in-process — see README) ---
# Chat: default 30 requests / hour
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_CHAT_WINDOW_MS=3600000

# Exposure audit: default 3 requests / hour
RATE_LIMIT_AUDIT_MAX=3
RATE_LIMIT_AUDIT_WINDOW_MS=3600000
